# ============================================================
# CVEBox — .env Configuration
# Copy this file to .env and fill in your values.
# Each TARGET_X block = one independent application to scan.
# ============================================================

# ---- Target Application 1 — Ecommerce / Web app ----
TARGET_NAME=My Ecommerce App
TARGET_URL=https://myapp.com/home
TARGET_LOGIN_URL=https://myapp.com/login
TARGET_USERNAME=user@myapp.com
TARGET_PASSWORD=mypassword

# Optional: CSS selectors if auto-detection fails (enterprise apps, custom UI)
# TARGET_USERNAME_SELECTOR=#input-email
# TARGET_PASSWORD_SELECTOR=#input-password
# TARGET_SUBMIT_SELECTOR=button[type="submit"]

# Optional: URL fragment expected AFTER login (to confirm session)
# Useful for SPAs or apps that redirect to a specific path after auth
# TARGET_POST_LOGIN_URL_CONTAINS=/dashboard

# Optional: HTTP headers to send in every request (JWT, API keys, etc.)
# TARGET_API_HEADERS={"Authorization":"Bearer eyJhbGci...","X-Tenant-ID":"acme"}

# ---- Target Application 2 — Enterprise Portal / Admin panel ----
# TARGET_2_NAME=Admin Portal
# TARGET_2_URL=https://admin.internal.com/overview
# TARGET_2_LOGIN_URL=https://admin.internal.com/auth/login
# TARGET_2_USERNAME=admin@internal.com
# TARGET_2_PASSWORD=adminpass
# TARGET_2_USERNAME_SELECTOR=[data-testid="username-input"]
# TARGET_2_PASSWORD_SELECTOR=[data-testid="password-input"]
# TARGET_2_SUBMIT_SELECTOR=[data-testid="login-button"]
# TARGET_2_POST_LOGIN_URL_CONTAINS=/overview

# ---- Target Application 3 — REST API (no browser UI) ----
# TARGET_3_NAME=Payments API
# TARGET_3_URL=https://api.mycompany.com/v1/products
# TARGET_3_LOGIN_URL=https://api.mycompany.com/v1/auth/login
# TARGET_3_USERNAME=api_user
# TARGET_3_PASSWORD=api_password
# TARGET_3_API_HEADERS={"X-API-Key":"your-key","Content-Type":"application/json"}

# ---- Target Application 4 — SPA with JWT auth ----
# TARGET_4_NAME=React Dashboard
# TARGET_4_URL=https://dashboard.mycompany.com
# TARGET_4_LOGIN_URL=https://dashboard.mycompany.com/login
# TARGET_4_USERNAME=qa@mycompany.com
# TARGET_4_PASSWORD=qapassword
# TARGET_4_POST_LOGIN_URL_CONTAINS=/dashboard
# TARGET_4_API_HEADERS={"Authorization":"Bearer TOKEN_WILL_BE_INJECTED_AFTER_LOGIN"}

# ---- Browser Settings ----
# true = visible browser window (headed mode, useful for debugging)
# false = headless (for CI/CD pipelines: AzDo, Jenkins, GitHub Actions)
BROWSER_HEADED=false

# ---- Scan Settings ----
# Timeout in ms per individual request (default: 8000)
SCAN_TIMEOUT_MS=8000

# Directory where HTML reports are saved (one report per app per scan)
REPORTS_DIR=./reports
