# ============================================================
# CVEBox — .env Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ---- Target Application 1 ----
TARGET_NAME=My App
TARGET_URL=https://ecommerce-playground.lambdatest.io/index.php?route=common/home
TARGET_LOGIN_URL=https://ecommerce-playground.lambdatest.io/index.php?route=account/login
TARGET_USERNAME=your@email.com
TARGET_PASSWORD=yourpassword

# Optional: override auto-detected selectors
# TARGET_USERNAME_SELECTOR=#input-email
# TARGET_PASSWORD_SELECTOR=#input-password
# TARGET_SUBMIT_SELECTOR=button[type="submit"]

# Optional: custom API headers as JSON string
# TARGET_API_HEADERS={"Authorization":"Bearer token123","X-API-Key":"abc"}

# ---- Target Application 2 (optional) ----
# TARGET_2_NAME=Another App
# TARGET_2_URL=https://yourapp2.com/home
# TARGET_2_LOGIN_URL=https://yourapp2.com/login
# TARGET_2_USERNAME=user2@email.com
# TARGET_2_PASSWORD=password2

# ---- Browser Settings ----
# Set to "true" to open a visible browser window (useful for debugging)
BROWSER_HEADED=false

# ---- Scan Settings ----
# Timeout in milliseconds per request (default: 8000)
SCAN_TIMEOUT_MS=8000

# Output directory for HTML reports (default: ./reports)
REPORTS_DIR=./reports
